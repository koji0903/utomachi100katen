# =====================================================================
# .env.example — 環境変数テンプレート
#
# 使い方:
#   1. このファイルを `.env.local` にコピーして、実際の値を入れる
#   2. `.env.local` は .gitignore 済み（コミット禁止）
#   3. Vercel 環境へは Vercel ダッシュボードで Production / Preview ごとに設定
#
# 環境別の接続先:
#   - Production (main)      → 本番 Firebase プロジェクト
#   - Preview   (staging/*)  → staging Firebase プロジェクト (utomachi100katen-staging-d6583)
#   - Development (local)    → Firebase Emulator Suite
#
# Emulator でローカル開発する場合は NEXT_PUBLIC_USE_EMULATOR=true を指定する
# （その他 NEXT_PUBLIC_FIREBASE_* はダミー値でも動作する）
# =====================================================================

# ---------- Firebase (client) ----------
# 本番値は Vercel Production にのみ設定し、ここには書かないこと
# Preview/ローカルに書く場合は staging プロジェクトの値を入れる
NEXT_PUBLIC_FIREBASE_API_KEY="AIzaSy__REPLACE__"
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="your-project.firebaseapp.com"
NEXT_PUBLIC_FIREBASE_PROJECT_ID="your-project-id"
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET="your-project-id.firebasestorage.app"
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID="000000000000"
NEXT_PUBLIC_FIREBASE_APP_ID="1:000000000000:web:xxxxxxxxxxxxxxxxxxxxxx"

# Emulator を使う場合に "true" を指定（ローカル開発時のみ）
# Production / Preview では未設定にしておくこと
NEXT_PUBLIC_USE_EMULATOR=""

# ---------- Firebase (admin / server) ----------
# サービスアカウント JSON を丸ごと 1 行に minify して文字列として貼る
# または GOOGLE_APPLICATION_CREDENTIALS でファイルパスを指定（どちらか一方）
FIREBASE_SERVICE_ACCOUNT_KEY=""

# ローカル開発で JSON ファイルを参照する場合はこちら
# GOOGLE_APPLICATION_CREDENTIALS="./secrets/your-service-account.json"

# ---------- 外部 API ----------
GEMINI_API_KEY=""
OPENWEATHER_API_KEY=""

# Gmail (メール送信)
GMAIL_USER=""
GMAIL_APP_PASSWORD=""

# Amazon SP-API
AMAZON_APP_CLIENT_ID=""
AMAZON_APP_CLIENT_SECRET=""
AMAZON_REFRESH_TOKEN=""
AMAZON_SELLER_ID=""
AMAZON_PRODUCT_TYPE="PRODUCT"
# staging では true 推奨 (Sandbox エンドポイント)
AMAZON_USE_SANDBOX="true"

# Shopify (Admin API)
SHOPIFY_STORE_DOMAIN=""
SHOPIFY_ADMIN_ACCESS_TOKEN=""
SHOPIFY_WEBHOOK_SECRET=""

# Square
SQUARE_APPLICATION_ID=""
SQUARE_ACCESS_TOKEN=""
SQUARE_LOCATION_ID=""
# staging では "sandbox" 推奨
SQUARE_ENVIRONMENT="sandbox"

# Vercel Cron 認証
CRON_SECRET=""
