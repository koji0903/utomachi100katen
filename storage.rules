rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Helper: check authentication
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper: validate file size (15 MB max)
    // 注意: write (create/update) 時のみ有効。read 時は request.resource が null のため使用不可。
    function isValidFileSize() {
      return request.resource.size <= 15 * 1024 * 1024;
    }

    // 共通のルール定義
    // read と write を分離し、read 時にはファイルサイズチェックを行わないようにします。
    // これにより、アップロード直後の getMetadata や getDownloadURL での権限エラーを回避します。
    
    match /products/{allPaths=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && isValidFileSize();
    }

    match /print-archives/{allPaths=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && isValidFileSize();
    }

    match /settings/{allPaths=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && isValidFileSize();
    }

    match /stores/{allPaths=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && isValidFileSize();
    }

    match /invoices/{allPaths=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && isValidFileSize();
    }

    match /delivery_notes/{allPaths=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && isValidFileSize();
    }

    match /receipts/{allPaths=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && isValidFileSize();
    }

    match /summaries/{allPaths=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && isValidFileSize();
    }

    match /reports/{allPaths=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && isValidFileSize();
    }

    // Default deny all (最後に配置)
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
